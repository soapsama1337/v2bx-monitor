#!/bin/sh
# Alpine Linux 专用守护脚本 - 兼容 ash/sh

# 1. 核心环境变量：Alpine 的 Cron 环境极其精简，必须手动声明路径
export PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

# 2. 定义变量（使用你 which 出来的绝对路径）
CHECK_CMD="/usr/bin/pgrep -x v2bx"
RESTART_CMD="/usr/bin/v2bx restart"
LOG_FILE="/var/log/v2bx_monitor.log"

# 3. 监控逻辑：直接扫描进程表
if ! $CHECK_CMD > /dev/null; then
    echo "$(date '+%Y-%m-%d %H:%M:%S') - [Alpine] 进程消失，正在执行重启..." >> $LOG_FILE
    $RESTART_CMD >> $LOG_FILE 2>&1
fi
